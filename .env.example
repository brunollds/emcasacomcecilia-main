# YouTube API (para o carrossel de vídeos na home)
YOUTUBE_API_KEY=sua_chave_aqui
YOUTUBE_CHANNEL_ID=seu_channel_id_aqui

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_PROPERTY_ID=000000000

# Receitas Populares via GA (ativar depois de coletar dados)
GA_POPULAR_RECIPES_ENABLED=false
GA_POPULAR_RECIPES_ACTIVATE_AFTER=2026-05-18

# Google Service Account (para leitura de analytics)
GOOGLE_CLIENT_EMAIL=sua-service-account@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Resend (formulário de contato — resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
